{
  "id": "tailscale-multi",
  "name": "Tailscale Multi",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.0.0",
  "author": "gliby",
  "license": "MIT",
  "description": "Monitor multiple Tailscale instances in one unified view. Status and peers per tailnet, no controls.",
  "tags": [
    "Bar",
    "Network",
    "Panel"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "refreshInterval": 5000,
      "compactMode": true,
      "hideDisconnected": false,
      "showSearchBar": false,
      "terminalCommand": "kitty",
      "sshUsername": "",
      "pingCount": 5,
      "defaultPeerAction": "copy-ip"
    }
  }
}
