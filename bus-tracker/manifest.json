{
  "id": "bus-tracker",
  "name": "Bus Tracker",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.0.0",
  "author": "gliby",
  "license": "MIT",
  "description": "Live bus arrival times for Israeli transit stops via curlbus API. Shows real-time ETAs with live/scheduled indicators.",
  "tags": ["Bar", "Panel"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "stopCode": "21477",
      "lines": ["32", "33", "54"],
      "refreshInterval": 30000,
      "compactMode": true
    }
  }
}
